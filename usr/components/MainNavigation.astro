---
import { Home, Users, Newspaper, Edit, LibraryBig, Code, GraduationCap, Menu, X } from "lucide-react"

interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

// Navigation items configuration
const menuItems = [
  { 
    href: "/", 
    label: "Inizio", 
    isActive: currentPath === "/",
    icon: "home"
  },
  {
    href: "/chi-siamo/",
    label: "Chi siamo",
    isActive: currentPath === "/chi-siamo/",
    icon: "users"
  },
  {
    href: "/notizie/",
    label: "Notizie",
    isActive: currentPath.startsWith("/notizie/"),
    icon: "newspaper"
  },
  { 
    href: "/blog/", 
    label: "Blog", 
    isActive: currentPath.startsWith("/blog/"),
    icon: "edit"
  },
  {
    href: "/ricerca/",
    label: "Ricerca",
    isActive: currentPath.startsWith("/ricerca/"),
    icon: "library-big"
  },
  {
    href: "/sviluppo/",
    label: "Sviluppo",
    isActive: currentPath.startsWith("/sviluppo/"),
    icon: "code"
  },
  {
    href: "/didattica/",
    label: "Didattica",
    isActive: currentPath.startsWith("/didattica/"),
    icon: "graduation-cap"
  },
]
---

<nav class="navbar bg-body-tertiary navbar-expand-md border-top border-bottom">
  <div class="container-sm">
    <button
      id="navbar-toggler"
      class="navbar-toggler border-0 p-2"
      type="button"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="toggler-icon-open"><Menu size={24} /></span>
      <span class="toggler-icon-close" style="display:none"><X size={24} /></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav mb-md-0 mx-auto">
        {
          menuItems.map(item => (
            <li class="nav-item fw-bold mx-auto mx-md-0 px-md-3 py-1">
              <a
                class:list={["nav-link d-flex flex-row flex-md-column align-items-center", item.isActive ? "active" : ""]}
                href={item.href}
              >
                {item.icon === "home" && <Home size={20} />}
                {item.icon === "users" && <Users size={20} />}
                {item.icon === "newspaper" && <Newspaper size={20} />}
                {item.icon === "edit" && <Edit size={20} />}
                {item.icon === "library-big" && <LibraryBig size={20} />}
                {item.icon === "code" && <Code size={20} />}
                {item.icon === "graduation-cap" && <GraduationCap size={20} />}
                <span class={item.icon ? "ms-2 mt-md-1 ms-md-0" : ""}>{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</nav>

<script>
  const toggler = document.getElementById('navbar-toggler');
  const target = document.getElementById('navbarNav');

  if (toggler && target) {
    toggler.addEventListener('click', () => {
      const isOpen = target.classList.toggle('show');
      toggler.setAttribute('aria-expanded', String(isOpen));
      const openIcon = toggler.querySelector('.toggler-icon-open') as HTMLElement;
      const closeIcon = toggler.querySelector('.toggler-icon-close') as HTMLElement;
      if (openIcon) openIcon.style.display = isOpen ? 'none' : '';
      if (closeIcon) closeIcon.style.display = isOpen ? '' : 'none';
    });
  }
</script>
