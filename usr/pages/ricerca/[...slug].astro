---
import ArticlePage from "../../components/ArticlePage.astro"
import { getCollection } from "astro:content"

export const prerender = true

export async function getStaticPaths() {
  const articles = await getCollection("ricerca")
  return articles.map(article => ({
    params: { slug: article.id.replace(".md", "") },
    props: { collection: "ricerca", slug: article.id.replace(".md", "") }
  }))
}

const { collection, slug } = Astro.props;
---
<ArticlePage
  collection={collection}
  slug={slug}
  backHref="/ricerca/"
  backLabel="← Torna indietro alla pagina principale della Ricerca"
/>



