---
import "../styles/global.css"
import SEO from "../../core/components/SEO/SEO.astro"
import { siteMetadata } from "../user.config.mjs"
import MainNavigation from "../components/MainNavigation.astro"

interface Props {
  title?: string
  description?: string
}

const { title = siteMetadata.title, description = siteMetadata.description } =
  Astro.props

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} siteMetadata={siteMetadata} />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class="bg-white min-vh-100 d-flex flex-column">
    <header>
      <div class="container-fluid container-xl px-4 py-4">
        <!-- First row: Logos and Mobile Menu Button -->
        <div class="d-flex justify-content-between align-items-center mb-4">
          <a
            href="/"
            class="d-inline-block opacity-hover"
            title={siteMetadata.title}
          >
            <img
              src="/images/lad-blue.png"
              alt="LAD - Laboratorio di Archeologia Digitale"
              style="max-width: 250px !important;"
            />
          </a>

          <a
            href="https://www.uniroma1.it/"
            target="_blank"
            class="d-inline-block opacity-hover"
            title="Sapienza Università di Roma"
          >
            <img
              src="/images/sapienza.png"
              alt="Sapienza Università di Roma"
              style="max-width: 250px !important;"
            />
          </a>
        </div>
      </div>

      <MainNavigation currentPath={currentPath} />
    </header>

    <main class="flex-grow-1">
      <div class="container px-4 py-5">
        <slot />
      </div>
    </main>

    <footer class="lad-footer">
      <div class="container px-4 py-5">
        <div class="row g-4 text-center text-md-start">
          <!-- LAD Info -->
          <div class="col-12 col-md-4">
            <div
              class="lad-logo mb-3 mx-auto mx-md-0"
              style="height: 2rem; width: 6rem; mask: url('/images/lad.svg') no-repeat center / contain; -webkit-mask: url('/images/lad.svg') no-repeat center / contain; background-color: var(--color-text-muted);"
            >
            </div>
            <h5 class="fw-semibold text-dark mb-2">
              Laboratorio di Archeologia Digitale alla Sapienza
            </h5>
            <p class="small text-muted">
              Responsabile scientifico: Julian Bogdani
            </p>
          </div>

          <!-- Department Info -->
          <div class="col-12 col-md-4">
            <h5 class="fw-semibold text-dark mb-2">
              <a
                href="https://saras.uniroma1.it/"
                class="text-primary text-decoration-none"
                title="Dipartimento SARAS Sapienza Università di Roma"
              >
                Dipartimento di Storia Antropologia Religioni Arte Spettacolo<br
                />
                Sapienza Università di Roma
              </a>
            </h5>
          </div>

          <!-- Privacy Note -->
          <div class="col-12 col-md-4">
            <h5 class="fw-semibold text-dark mb-2">
              Nota sulla <em>privacy</em>
            </h5>
            <p class="small text-muted">
              Questo sito <strong>non</strong> traccia l'attività dei suoi lettori
              e <strong>non</strong> raccoglie dati personali sulla navigazione, cronologia,
              preferenze, indirizzo IP, geolocalizzazione o altre informazioni personali,
              aggregate o meno. Il LAD ha scelto di non raccogliere statistiche sul
              proprio utilizzo per difendere il diritto alla riservatezza dei propri
              utenti.
            </p>
          </div>
        </div>

        <div class="mt-5 pt-4 border-top text-center">
          <p class="small text-muted">
            Questo sito è stato realizzato con
            <a
              href="https://github.com/lad-sapienza/scms"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary text-decoration-none"
            >
              s:CMS
            </a>
            da LAD @Sapienza
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
